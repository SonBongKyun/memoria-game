; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="MEMORIA: The Price of Oblivion"
config/description="A dark fantasy RPG where memories are the price of power."
config/version="0.1.0"
run/main_scene="res://scenes/main/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0.02, 0.02, 0.05, 1)
boot_splash/show_image=false
config/icon="res://icon.svg"
config/windows_native_icon="res://icon.ico"

[autoload]

GameManager="*res://scripts/core/game_manager.gd"
MemoryManager="*res://scripts/systems/memory_manager.gd"
DialogueManager="*res://scripts/systems/dialogue_manager.gd"
SceneTransition="*res://scripts/core/scene_transition.gd"
DialogueBox="*res://scripts/ui/dialogue_box.gd"
MemoryUI="*res://scripts/ui/memory_ui.gd"
SystemLog="*res://scripts/ui/system_log.gd"
BattleManager="*res://scripts/systems/battle_manager.gd"
SaveManager="*res://scripts/systems/save_manager.gd"
CgViewer="*res://scripts/ui/cg_viewer.gd"
AudioManager="*res://scripts/systems/audio_manager.gd"
PauseMenu="*res://scripts/ui/pause_menu.gd"
OptionsMenu="*res://scenes/ui/options_menu.gd"
ExplorationHUD="*res://scripts/ui/exploration_hud.gd"
NotificationToast="*res://scripts/ui/notification_toast.gd"
MemoryShop="*res://scripts/ui/memory_shop.gd"
StoryJournal="*res://scripts/ui/story_journal.gd"
AchievementManager="*res://scripts/ui/achievement_manager.gd"
Codex="*res://scripts/ui/codex.gd"
MemoryPuzzle="*res://scripts/ui/memory_puzzle.gd"
EliaDiary="*res://scripts/ui/elia_diary.gd"
Dialogic="*uid://ds2q0uclmolvu"
TutorialHints="*res://scripts/ui/tutorial_hints.gd"
InputManager="*res://scripts/systems/input_manager.gd"

[dialogic]

directories/dch_directory={}
directories/dtl_directory={}
layout/style_directory={}

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/size/resizable=true
window/stretch/mode="viewport"
window/stretch/aspect="keep"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg", "res://addons/shaderV/plugin.cfg", "res://addons/vfx_lib/plugin.cfg")

